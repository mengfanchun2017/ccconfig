{
  "description": "MCP 配置 — 整合 MCP 服务器列表和 env 配置",
  "_note": "MCP Key 为占位符，运行 bash ccconfig/lib/init-mcp.sh keys 交互式填写",
  "env": {
    "CLAUDE_CODE_DISABLE_NONESSENTIAL_TRAFFIC": "1"
  },
  "settings": {
    "default_action": "sync",
    "auto_config_keys": true
  },
  "mcp_servers": [
    {
      "name": "tavily",
      "description": "Web 搜索（英文）",
      "how_to_get": "去 https://tavily.com 注册，免费额度 1000 次/月",
      "type": "stdio",
      "command": "npx",
      "args": ["-y", "tavily-mcp"],
      "env": {
        "TAVILY_API_KEY": "请到 https://tavily.com 注册获取 API Key"
      }
    },
    {
      "name": "minimax",
      "description": "MiniMax AI - 中文搜索和图片理解",
      "how_to_get": "去 https://platform.minimax.io 注册",
      "type": "stdio",
      "command": "uvx",
      "args": ["minimax-coding-plan-mcp", "-y"],
      "env": {
        "MINIMAX_API_KEY": "请填入你的 MiniMax API Key",
        "MINIMAX_API_HOST": "https://api.minimax.chat"
      }
    },
    {
      "name": "minimax-mcp",
      "description": "MiniMax 多模态 - 语音/视频/图像/音乐生成",
      "how_to_get": "共用 Minimax Key，无需额外注册",
      "type": "stdio",
      "command": "uvx",
      "args": ["minimax-mcp"],
      "env": {
        "MINIMAX_API_KEY": "请填入你的 MiniMax API Key",
        "MINIMAX_API_HOST": "https://api.minimax.chat"
      }
    },
    {
      "name": "supabase",
      "description": "Supabase 数据库",
      "disabled": true,
      "how_to_get": "去 https://supabase.com 创建项目 → Project Settings 获取 project-ref 和 access-token",
      "type": "stdio",
      "command": "npx",
      "args": [
        "-y",
        "@supabase/mcp-server-supabase",
        "--project-ref", "请填入你的 Supabase project ref",
        "--access-token", "请填入你的 Supabase access token"
      ],
      "env": {}
    }
  ]
}
