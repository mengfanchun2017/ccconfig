#!/bin/bash
#
# pre-commit hook: 自动备份 MEMORY.md 到 claude-config 仓库
#
# 使用方法：
# 1. 将此文件复制到: .git/hooks/pre-commit (去掉 .example 后缀)
# 2. Windows: Git Bash 可以直接运行
# 3. Linux/Mac: chmod +x .git/hooks/pre-commit
#

echo "=== 正在自动备份 MEMORY.md... ==="

# 源文件路径（用户级别的 MEMORY.md）
# Windows Git Bash 下用 $HOME
SOURCE_MEMORY="$HOME/.claude/projects/C--git/memory/MEMORY.md"

# 目标路径（claude-config 仓库里的 memory 目录）
DEST_DIR="$(dirname "$0")/../memory"
DEST_MEMORY="$DEST_DIR/MEMORY.md"

# 规范化路径
DEST_DIR="$(cd "$DEST_DIR" && pwd)"
DEST_MEMORY="$DEST_DIR/MEMORY.md"

# 创建目标目录（如果不存在）
mkdir -p "$DEST_DIR"

# 复制文件
if [ -f "$SOURCE_MEMORY" ]; then
  cp "$SOURCE_MEMORY" "$DEST_MEMORY"
  echo "✅ MEMORY.md 已备份到: $DEST_MEMORY"

  # 自动添加到 Git
  cd "$(dirname "$0")/.."
  git add "memory/MEMORY.md"
  echo "✅ 已添加到 Git 暂存区"
else
  echo "⚠️  源文件不存在: $SOURCE_MEMORY"
fi

echo "=== 备份完成 ==="

# 返回 0 表示成功，继续 commit
exit 0
