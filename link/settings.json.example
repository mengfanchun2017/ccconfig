{
    "env": {
        "ANTHROPIC_BASE_URL": "https://api.deepseek.com/anthropic",
        "ANTHROPIC_MODEL": "deepseek-v4-pro",
        "CLAUDE_CODE_DISABLE_NONESSENTIAL_TRAFFIC": "1",
        "ANTHROPIC_AUTH_TOKEN": "请填入你的 API Key",
        "ANTHROPIC_DEFAULT_HAIKU_MODEL": "deepseek-v4-pro"
    },
    "permissions": {
        "allow": [
            "Bash(*)",
            "Edit(**/*.md)",
            "Edit(**/*.json)",
            "Edit(**/*.sh)",
            "Edit(**/*.py)",
            "Edit(**/*.ts)",
            "Edit(**/*.js)",
            "Write(**/*)",
            "Read(**/*)",
            "Glob(**/*)",
            "Grep(**/*)"
        ],
        "defaultMode": "bypassPermissions"
    },
    "hooks": {
        "SessionStart": [
            {
                "matcher": "",
                "hooks": [
                    {
                        "type": "command",
                        "command": "bash $HOME/git/ccconfig/status.sh"
                    }
                ]
            }
        ]
    },
    "statusLine": {
        "type": "command",
        "command": "true"
    },
    "skipDangerousModePermissionPrompt": true,
    "autoUpdatesChannel": "stable",
    "mcpServers": {
        "_comment": "MCP server 配置。API key 填入 env 块，不要提交到公开仓库。",
        "tavily": {
            "command": "npx",
            "args": ["-y", "tavily-mcp"],
            "env": {
                "TAVILY_API_KEY": "<your-tavily-key>"
            }
        },
        "getnote": {
            "command": "npx",
            "args": ["-y", "@getnote/mcp"],
            "env": {
                "GETNOTE_API_KEY": "<your-getnote-api-key>",
                "GETNOTE_CLIENT_ID": "<your-getnote-client-id>"
            }
        },
        "minimax": {
            "command": "uvx",
            "args": ["minimax-mcp"],
            "env": {
                "MINIMAX_API_KEY": "<your-minimax-key>",
                "MINIMAX_API_HOST": "https://api.minimax.chat"
            }
        },
        "supabase": {
            "command": "npx",
            "args": ["-y", "@supabase/mcp-server-supabase", "--project-ref", "<your-project-ref>"],
            "env": {
                "SUPABASE_ACCESS_TOKEN": "<your-supabase-token>"
            }
        }
    }
}
