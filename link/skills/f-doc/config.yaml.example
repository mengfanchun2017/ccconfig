# f-doc 用户配置（示例）
# 复制为 link/skills/f-doc/config.yaml → symlink 到 ccprivate/link/skills/f-doc/config.yaml

settings:
  default_parent_token:
    value: "<your-wiki-node-token>"
    description: "独立文档默认父节点（飞书 wiki token）"
    type: string

  default_domain:
    value: "<your-tenant>.feishu.cn"
    description: "飞书域名（不含 https://）"
    type: string

  lark_account:
    value: "ailab"
    description: "默认飞书账号（对应 ~/.lark-cli-<account>）"
    type: string
