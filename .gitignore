# Claude Code 本地配置（包含 API Key，不同步）
.claude.json

# GetNote 等外部工具配置（包含 API Key）
openclaw.json


# auto-sync 运行文件
.auto-sync.log
.auto-sync.pid
.monitor-sync.log
.monitor-sync.pid
.monitor-sync.debounce

# 升级快照（init-update.sh 自动生成，仅用于调试）
.snapshots/

# 编辑器/工具原子写入残留
*.tmp.*

# 可选：本地环境变量文件
# .env

# 临时文件/脚本（一次性任务产物）
tmp/
