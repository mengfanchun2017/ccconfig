# Claude Code 本地配置（包含 API Key，不同步）
.claude.json

# GetNote 等外部工具配置（包含 API Key）
openclaw.json

# 真实配置文件（含 API key / token）— ADR-0001，仓库公开后不可 commit 真实 key
conf/llm.json
conf/claude.json
conf/feishu.json
conf/ubuntu.json
link/.config.json
# link/settings.json 含 ANTHROPIC_AUTH_TOKEN + TAVILY_API_KEY + MINIMAX_API_KEY + supabase access-token，2026-06-12 起 ignore（之前漏 ignore，参考 ADR-0001）
link/settings.json


# auto-sync 运行文件
.auto-sync.log
.auto-sync.pid
.monitor-sync.log
.monitor-sync.pid
.monitor-sync.debounce
.monitor-sync.changed-repos

# 升级快照（init-update.sh 自动生成，仅用于调试）
.snapshots/

# 编辑器/工具原子写入残留
*.tmp.*

# 可选：本地环境变量文件
# .env

# 临时文件/脚本（一次性任务产物）
tmp/

# Windows 工具目录下的二进制（6.8M，单独从 release 下载；脚本 commit 即可）
windows-tools/**/ncmdump.exe
.tmp/
